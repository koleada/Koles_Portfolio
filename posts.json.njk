---
permalink: "/posts.json"
---
[
{% for post in collections.posts %}
  {
    "title": {{ post.data.title | dump | safe }},
    "date": {{ post.date.toISOString().slice(0,10) | dump | safe }},
    "description": {{ post.data.description | dump | safe }},
    "tags": {{ (post.data.tags or []) | dump | safe }},
    "image": {{ post.data.image | dump | safe }},
    "url": {{ post.url | dump | safe }}
  }{% if not loop.last %},{% endif %}
{% endfor %}
]